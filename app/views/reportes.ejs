function cerrarModal(){document.getElementById('modal-detalle').classList.remove('active');currentActa=null;}

function generarFirmaTexto(nombre){
  const canvas=document.getElementById('firma-canvas');
  if(!canvas)return null;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,canvas.width,canvas.height);
  ctx.font='italic 32px Georgia, "Times New Roman", serif';
  ctx.fillStyle='#1a1a6e';
  ctx.textAlign='center';
  ctx.textBaseline='middle';
  ctx.fillText(nombre,canvas.width/2,canvas.height/2);
  // Linea decorativa
  ctx.strokeStyle='#1a1a6e';
  ctx.lineWidth=1;
  ctx.beginPath();
  const textW=ctx.measureText(nombre).width;
  ctx.moveTo((canvas.width-textW)/2-10,canvas.height/2+20);
  ctx.lineTo((canvas.width+textW)/2+10,canvas.height/2+20);
  ctx.stroke();
  return canvas.toDataURL('image/png');
}

function getFirmaBase64(){
  const c=document.getElementById('firma-canvas');
  if(!c)return null;
  const b=document.createElement('canvas');b.width=c.width;b.height=c.height;
  if(c.toDataURL()===b.toDataURL())return null;
  return c.toDataURL('image/png');
}

function firmarYAceptar(){
  if(!currentActa)return;
  const persona=document.getElementById('res-persona').value.trim();
  if(!persona){toast(currentActa.destino==='planta'?'Ingresa el nombre del operador.':'Indica quien acepta.','error');return;}
  const obs=document.getElementById('res-obs').value.trim();
  const msg=obs
    ?'Se firmara el acta con las observaciones ingresadas. Confirma la aceptacion?'
    :'No se ingresaron observaciones. Desea firmar y aceptar el acta?';
  rptConfirm('Firmar acta', msg, function(){
    generarFirmaTexto(persona);
    document.getElementById('firma-preview').style.display='block';
    setTimeout(()=>procesarResguardo('aceptada'),300);
  });
}

function procesarResguardo(estado){
  if(!currentActa)return;
  const persona=document.getElementById('res-persona').value.trim();
  if(!persona){toast(currentActa.destino==='planta'?'Ingresa el nombre del operador.':'Indica quien acepta.','error');return;}
  if(estado==='rechazada'){
    rptConfirm('Rechazar acta','Confirma el RECHAZO del acta?',function(){ ejecutarResguardo(estado); });
    return;
  }
  ejecutarResguardo(estado);
}
async function ejecutarResguardo(estado){
  if(!currentActa)return;
  const persona=document.getElementById('res-persona').value.trim();
  const firma=getFirmaBase64();
  const esPlanta=(currentActa.destino||'oficina')==='planta';
  const aceptadaPor=esPlanta?(userName+' - '+persona):persona;
  try{const resp=await fetch('/actas/api/resguardo',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id:currentActa.id,estado,aceptada_por:aceptadaPor,observaciones:document.getElementById('res-obs').value.trim(),firma})});const data=await resp.json();if(data.ok){toast(estado==='aceptada'?'Acta aceptada y firmada':'Acta rechazada');cerrarModal();cargarActas();cargarPendientes();}else toast('Error: '+(data.error||''),'error');}catch(e){toast('Error: '+e.message,'error');}}

function imprimirDesdeModal(){const doc=document.querySelector('#modal-body .acta-doc');if(!doc)return;const contenido=doc.innerHTML;cerrarModal();const w=window.open('','_blank','width=800,height=600');w.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><title>Acta</title><style>@page{margin:12mm 15mm;size:A4;}*{box-sizing:border-box;-webkit-print-color-adjust:exact!important;}body{font-family:Arial,sans-serif;color:#000;background:#fff;margin:0;padding:10mm;}.acta-header{border-bottom:2px solid #000;padding-bottom:10px;margin-bottom:14px;}.acta-logo-row{display:flex;align-items:center;justify-content:space-between;}.acta-titulo{font-size:13px;font-weight:700;text-align:right;}.acta-meta{display:flex;justify-content:space-between;margin-bottom:12px;font-size:11px;background:#f5f5f5;padding:5px 8px;}.acta-section{margin-bottom:10px;}.acta-section-title{font-size:10px;font-weight:900;text-transform:uppercase;background:#111;color:#fff;padding:3px 8px;margin-bottom:6px;}.acta-equipos-table{width:100%;border-collapse:collapse;font-size:10px;}.acta-equipos-table th{background:#333;color:#fff;padding:4px 6px;text-align:left;font-size:9px;text-transform:uppercase;}.acta-equipos-table td{padding:4px 6px;border-bottom:1px solid #ddd;}.acta-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px;}.acta-field{display:flex;flex-direction:column;}.af-label{font-size:8px;font-weight:700;text-transform:uppercase;color:#666;}.af-value{font-size:11px;font-weight:700;border-bottom:1px solid #ddd;min-height:16px;}.acta-obs{border:1px solid #ccc;padding:6px;min-height:40px;font-size:11px;}.acta-firmas{display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-top:24px;}.acta-firma{text-align:center;}.firma-linea{border-top:1px solid #000;margin-top:36px;margin-bottom:4px;}.firma-nombre{font-size:11px;font-weight:700;}.firma-cargo{font-size:10px;color:#555;}.acta-footer{margin-top:14px;text-align:center;font-size:9px;color:#888;border-top:1px solid #ccc;padding-top:6px;}</style></head><body>'+contenido+'</body></html>');w.document.close();w.onload=()=>{w.focus();w.print();w.onafterprint=()=>w.close();};}

async function cargarEstadisticas(){try{const stats=await fetch('/actas/api/estadisticas').then(r=>r.json());const g=stats.general||{};const pe=stats.por_estado||[];const pend=pe.find(e=>e.estado==='pendiente')?.total||0;const acep=pe.find(e=>e.estado==='aceptada')?.total||0;const rech=pe.find(e=>e.estado==='rechazada')?.total||0;document.getElementById('stats-cards').innerHTML=`<div class="stat-card"><div class="stat-number">${g.total||0}</div><div class="stat-label">Total Actas</div></div><div class="stat-card"><div class="stat-number">${g.equipos||0}</div><div class="stat-label">Total Equipos</div></div><div class="stat-card"><div class="stat-number" style="color:#d39e00;">${pend}</div><div class="stat-label">Pendientes</div></div><div class="stat-card"><div class="stat-number" style="color:#1e7e34;">${acep}</div><div class="stat-label">Aceptadas</div></div><div class="stat-card"><div class="stat-number" style="color:#a71d2a;">${rech}</div><div class="stat-label">Rechazadas</div></div>`;
const pt=stats.por_tipo||[];const maxT=Math.max(...pt.map(t=>t.total),1);const tc=pt.map(t=>{const p=Math.round((t.total/maxT)*100);const c=t.tipo==='entrega'?'#007bff':'#ff9800';return `<div class="bar-row"><div class="bar-label">${t.tipo==='entrega'?'Entrega':'Salida'}</div><div class="bar-track"><div class="bar-fill" style="width:${p}%;background:${c};">${t.total}</div></div></div>`;}).join('');
const pm=stats.por_mes||[];const meses=[...new Set(pm.map(m=>m.mes))].sort();const maxM=Math.max(...pm.map(m=>m.total),1);const mc=meses.map(mes=>{const total=pm.filter(m=>m.mes===mes).reduce((s,i)=>s+i.total,0);const p=Math.round((total/maxM)*100);const ml=new Date(mes+'-01T12:00:00').toLocaleDateString('es-EC',{month:'short',year:'2-digit'});return `<div class="bar-row"><div class="bar-label">${ml}</div><div class="bar-track"><div class="bar-fill" style="width:${p}%;background:var(--color-principal);">${total}</div></div></div>`;}).join('');
const tu=stats.top_usuarios||[];const maxU=Math.max(...tu.map(u=>u.total),1);const uc=tu.map(u=>{const p=Math.round((u.total/maxU)*100);return `<div class="bar-row"><div class="bar-label">${u.created_by}</div><div class="bar-track"><div class="bar-fill" style="width:${p}%;background:#6f42c1;">${u.total}</div></div></div>`;}).join('');
document.getElementById('stats-charts').innerHTML=`<div class="chart-card"><h3>Por Tipo</h3><div class="bar-chart">${tc||'<p style="color:var(--text-muted);font-size:12px;">Sin datos</p>'}</div></div><div class="chart-card"><h3>Por Mes (6 meses)</h3><div class="bar-chart">${mc||'<p style="color:var(--text-muted);font-size:12px;">Sin datos</p>'}</div></div><div class="chart-card"><h3>Top Usuarios</h3><div class="bar-chart">${uc||'<p style="color:var(--text-muted);font-size:12px;">Sin datos</p>'}</div></div><div class="chart-card"><h3>Por Estado</h3><div class="bar-chart">${pe.map(e=>{const colors={pendiente:'#ffc107',aceptada:'#28a745',rechazada:'#dc3545'};const p=Math.round((e.total/Math.max(...pe.map(x=>x.total),1))*100);return `<div class="bar-row"><div class="bar-label">${e.estado.charAt(0).toUpperCase()+e.estado.slice(1)}</div><div class="bar-track"><div class="bar-fill" style="width:${p}%;background:${colors[e.estado]||'#666'};">${e.total}</div></div></div>`;}).join('')||'<p style="color:var(--text-muted);font-size:12px;">Sin datos</p>'}</div></div>`;}catch(e){document.getElementById('stats-cards').innerHTML=`<div class="stat-card"><div class="stat-label">Error: ${e.message}</div></div>`;}}

document.addEventListener('click',e=>{if(e.target.id==='modal-detalle')cerrarModal();});
if(esAdmin)cargarPendientes();
else cargarMisPendientes();
</script>
</body>
