tino||'---'}</span></div><div class="acta-field"><span class="af-label">Retira</span><span class="af-value">${a.retira_persona||'---'}</span></div><div class="acta-field"><span class="af-label">Cargo</span><span class="af-value">${a.retira_cargo||'---'}</span></div></div></div>`;}
let estadoInfo='';if(a.estado!=='pendiente'){const fa=a.aceptada_fecha?new Date(a.aceptada_fecha).toLocaleString('es-EC'):'---';const firmaImg=a.firma_digital?`<div style="margin-top:10px;padding:10px;background:#fff;border-radius:6px;border:1px solid #ddd;text-align:center;"><div style="font-size:9px;color:#888;margin-bottom:4px;text-transform:uppercase;font-weight:700;">Firma</div><img src="${a.firma_digital}" style="max-height:60px;object-fit:contain;" alt="Firma"></div>`:'';estadoInfo=`<div style="margin-top:12px;padding:12px;border-radius:8px;background:${a.estado==='aceptada'?'rgba(40,167,69,0.08)':'rgba(220,53,69,0.08)'};border:1px solid ${a.estado==='aceptada'?'rgba(40,167,69,0.3)':'rgba(220,53,69,0.3)'}"><strong style="color:${a.estado==='aceptada'?'#1e7e34':'#a71d2a'}">${a.estado==='aceptada'?'&#9989; ACEPTADA':'&#10060; RECHAZADA'}</strong><div style="font-size:11px;color:var(--text-sub);margin-top:4px;"><div>Por: <strong>${a.aceptada_por||'---'}</strong></div><div>Fecha: ${fa}</div>${a.aceptada_observaciones?'<div>Obs: '+a.aceptada_observaciones+'</div>':''}</div>${firmaImg}</div>`;}
let html=`<div class="acta-doc"><div class="acta-header"><div class="acta-logo-row"><img src="${logo}" alt="${nombre}" onerror="this.style.display='none'" style="height:50px;"><div style="text-align:right;"><div class="acta-titulo">${tipoLabel}</div><div style="font-size:10px;color:#555;"><b>N&deg;</b> ${a.numero}</div></div></div></div><div class="acta-meta"><span><b>Fecha:</b> ${fechaF}</span><span><b>Lugar:</b> ${a.lugar||'---'}</span></div>${datosHTML}<div class="acta-section"><div class="acta-section-title">Equipos (${equipos.length})</div><table class="acta-equipos-table"><thead><tr><th>#</th><th>Nombre</th><th>Tipo</th><th>Fabricante</th><th>Modelo</th><th>S/N</th></tr></thead><tbody>${eqRows}</tbody></table></div><div class="acta-section"><div class="acta-section-title">Observaciones</div><div class="acta-obs">${a.observaciones||'Ninguna'}</div></div>${estadoInfo}<div class="acta-footer">${nombre} - Gestion de Activos TI - ${a.created_at?new Date(a.created_at).toLocaleString('es-EC'):'---'}</div></div>`;
if(modoResguardo&&a.estado==='pendiente'){const esPlanta=(a.destino||'oficina')==='planta';const sessionUser=userName;
if(esPlanta){html+=`<div class="resguardo-section"><h3>&#128221; Aceptacion / Resguardo <span style="font-size:11px;background:rgba(255,152,0,0.15);color:#e65100;padding:2px 8px;border-radius:10px;margin-left:8px;">Planta</span></h3><div style="font-size:11px;color:var(--text-muted);margin-bottom:12px;">Estacion: <strong>${sessionUser}</strong></div><div class="resguardo-grid"><div class="form-group"><label>Nombre y apellido del operador</label><input type="text" id="res-persona" placeholder="Ingrese nombre completo..."></div><div class="form-group"><label>Observaciones</label><input type="text" id="res-obs" placeholder="Si no tiene observaciones, deje vacio..."></div></div><div id="firma-preview" style="display:none;margin-top:12px;padding:16px;background:#fff;border-radius:8px;border:1px solid var(--border);text-align:center;"><canvas id="firma-canvas" width="500" height="80"></canvas></div><div class="resguardo-actions"><button class="btn-aceptar" onclick="firmarYAceptar()">&#9998; Firmar y Aceptar</button><button class="btn-rechazar" onclick="procesarResguardo('rechazada')">&#10060; Rechazar</button></div></div>`;}else{html+=`<div class="resguardo-section"><h3>&#128221; Aceptacion / Resguardo <span style="font-size:11px;background:rgba(0,123,255,0.12);color:#0056b3;padding:2px 8px;border-radius:10px;margin-left:8px;">Oficina</span></h3><div style="font-size:11px;color:var(--text-muted);margin-bottom:12px;">Aceptado por: <strong>${sessionUser}</strong></div><input type="hidden" id="res-persona" value="${sessionUser}"><div class="resguardo-grid"><div class="form-group"><label>Observaciones</label><input type="text" id="res-obs" placeholder="Si no tiene observaciones, deje vacio..."></div></div><div id="firma-preview" style="display:none;margin-top:12px;padding:16px;background:#fff;border-radius:8px;border:1px solid var(--border);text-align:center;"><canvas id="firma-canvas" width="500" height="80"></canvas></div><div class="resguardo-actions"><button class="btn-aceptar" onclick="firmarYAceptar()">&#9998; Firmar y Aceptar</button><button class="btn-rechazar" onclick="procesarResguardo('rechazada')">&#10060; Rechazar</button></div></div>`;}}else if(a.estado==='aceptada'){html+=`<div style="margin-top:16px;"><button class="btn-imprimir" onclick="imprimirDesdeModal()">&#128424; Imprimir / PDF</button></div>`;}
