          <button class="btn-sm btn-view" onclick="verDetalle(${a.id})" style="margin-right:4px;">&#128065; Ver</button>
          <button class="btn-sm btn-accept" onclick="autorizarSolicitud(${a.id},'autorizada')">&#9989; Autorizar</button>
          <button class="btn-sm" onclick="autorizarSolicitud(${a.id},'rechazada')" style="padding:5px 12px;border-radius:5px;border:1px solid rgba(220,53,69,0.3);background:rgba(220,53,69,0.1);color:#dc3545;font-size:11px;font-weight:700;cursor:pointer;margin-left:4px;">&#10060; Rechazar</button>
        </td>
      </tr>`;
    }).join('');
  }catch(e){tbody.innerHTML='<tr class="empty-row"><td colspan="7">Error: '+e.message+'</td></tr>';}
}

let proveedoresData = [];
async function cargarProveedoresReportes() {
  if (proveedoresData.length) return;
  try {
    const res = await fetch('/actas/api/proveedores');
    proveedoresData = await res.json();
  } catch(e) {}
}

async function autorizarSolicitud(id, accion){
  if(accion==='rechazada'){
    rptRechazo(async function(obs){
      const res=await fetch('/actas/api/autorizar-solicitud',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({id,accion,observaciones:obs})});
      const data=await res.json();
      if(data.ok){toast('Solicitud rechazada');cargarSolicitudes();}else toast(data.error||'Error','error');
    });
    return;
  }
  // Autorizar: pedir destino/proveedor
  await cargarProveedoresReportes();
  const sel = document.getElementById('rpt-autorizar-destino');
  sel.innerHTML = '<option value="">-- Seleccionar proveedor --</option>';
  proveedoresData.forEach(p => { const o = document.createElement('option'); o.value = p.name; o.textContent = p.name; sel.appendChild(o); });
  sel.innerHTML += '<option value="otro">Otro (escribir)</option>';
  document.getElementById('rpt-autorizar-destino-input').style.display = 'none';
  document.getElementById('rpt-autorizar-destino-input').value = '';
  document.getElementById('rpt-autorizar-id').value = id;
  document.getElementById('modal-rpt-autorizar').classList.add('active');
}

async function confirmarAutorizacion() {
  const id = parseInt(document.getElementById('rpt-autorizar-id').value);
  const sel = document.getElementById('rpt-autorizar-destino').value;
  const destino = sel === 'otro' ? document.getElementById('rpt-autorizar-destino-input').value.trim() : sel;
  if (!destino) { toast('Selecciona el destino/proveedor', 'error'); return; }
  document.getElementById('modal-rpt-autorizar').classList.remove('active');
  const res = await fetch('/actas/api/autorizar-solicitud', {
    method: 'POST', headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ id, accion: 'autorizada', destino, observaciones: '' }),
  });
  const data = await res.json();
  if (data.ok) { toast('Solicitud autorizada'); cargarSolicitudes(); }
  else toast(data.error || 'Error', 'error');
}

